{
    "name": "mcc-playwright-tests",
    "version": "1.0.0",
    "private": true,
    "description": "MCC / Lord's Cricket Ground QA automation project (Playwright + k6)",
    "scripts": {
        "test": "npx playwright test -c .",
        "test:headed": "npx playwright test -c . --headed",
        "test:ui": "npx playwright test -c . --ui",
        "test:nonfunctional": "npx playwright test -c . 09-mcc.nonfunctional.spec.js",
        "load:smoke": "k6 run --env SCENARIO=smoke 10-mcc.load.k6.js",
        "load:load": "k6 run --env SCENARIO=load 10-mcc.load.k6.js",
        "load:spike": "k6 run --env SCENARIO=spike 10-mcc.load.k6.js",
        "load:soak": "k6 run --env SCENARIO=soak 10-mcc.load.k6.js",
        "load:all": "k6 run 10-mcc.load.k6.js"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.2",
        "@playwright/test": "^1.52.0"
    }
}
